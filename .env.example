# Application
APP_NAME=FastAPI Minimal Template
APP_VERSION=0.1.0
DEBUG=true
RUN_SEEDS=false

# Server
HOST=0.0.0.0
PORT=8000
GRPC_PORT=50051

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/fastapi_minimal_template

# Cache (Redis)
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# Event Bus (Kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=fastapi-minimal-template
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=ap-southeast-1
AWS_S3_ENDPOINT_URL=

# LLM
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_API_KEY=
LLM_HOST=http://localhost:11434
LLM_USE_VERTEX_AI=false
LLM_VERTEX_PROJECT=
LLM_VERTEX_LOCATION=us-central1