{
    auto_https off
}

:443 {
    tls internal

    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:8000
    }

    handle /storage/* {
        uri strip_prefix /storage
        reverse_proxy minio:9000
    }

    handle {
        reverse_proxy frontend:3000
    }
}

:80 {
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:8000
    }

    handle /storage/* {
        uri strip_prefix /storage
        reverse_proxy minio:9000
    }

    handle {
        reverse_proxy frontend:3000
    }
}