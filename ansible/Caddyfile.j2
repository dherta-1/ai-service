{$DOMAIN:{{ domain }}} {
	# ── API ──────────────────────────────────────────────────────
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:8000
	}

	# ── MinIO S3 storage ────────────────────────────────────────
	handle /storage/* {
		uri strip_prefix /storage
		reverse_proxy minio:9000
	}

	# ── Frontend ─────────────────────────────────────────────────
	handle {
		reverse_proxy frontend:3000
	}
}
