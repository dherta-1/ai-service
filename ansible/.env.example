DOMAIN={{ domain }}
APP_NAME={{ app_name | default('Dherta AI Service') }}
APP_VERSION={{ app_version | default('0.1.0') }}
DEBUG={{ debug }}
LOG_RESULTS={{ log_results }}
RUN_SEEDS={{ run_seeds }}
HOST=0.0.0.0
PORT=8000
GRPC_PORT=50051
AWS_ACCESS_KEY_ID={{ minio_root_user }}
AWS_SECRET_ACCESS_KEY={{ minio_root_password }}
AWS_REGION={{ aws_region }}
AWS_S3_BUCKET={{ aws_s3_bucket }}
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_PUBLIC_URL={{ aws_s3_public_url }}
LLM_PROVIDER={{ llm_provider }}
LLM_MODEL={{ llm_model }}
LLM_EMBEDDING_MODEL={{ llm_embedding_model }}
LLM_EMBEDDING_DIMENSION={{ llm_embedding_dimension }}
LLM_API_KEY={{ llm_api_key }}
OCR_PROVIDER={{ ocr_provider }}
OCR_LANG={{ ocr_lang }}
OCR_USE_GPU={{ ocr_use_gpu }}
JWT_SECRET_KEY={{ jwt_secret_key }}
JWT_ALGORITHM={{ jwt_algorithm }}
ACCESS_TOKEN_EXPIRE_MINUTES={{ access_token_expire_minutes }}
REFRESH_TOKEN_EXPIRE_DAYS={{ refresh_token_expire_days }}
CORS_ORIGINS={{ cors_origins }}
CORS_ALLOW_CREDENTIALS={{ cors_allow_credentials }}
CORS_ALLOW_METHODS={{ cors_allow_methods }}
CORS_ALLOW_HEADERS={{ cors_allow_headers }}
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port }}
SMTP_USERNAME={{ smtp_username }}
SMTP_PASSWORD={{ smtp_password }}
SMTP_FROM_EMAIL={{ smtp_from_email }}
SMTP_FROM_NAME={{ smtp_from_name }}
FRONTEND_URL=https://{{ domain }}
KAFKA_CONSUMER_GROUP_ID=dherta-ai-service
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
QUESTION_GROUPING_THRESHOLD={{ question_grouping_threshold }}
