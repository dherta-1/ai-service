# ── Application ───────────────────────────────────────────────
APP_NAME=Dherta AI Service
APP_VERSION=0.1.0
DEBUG=false
LOG_RESULTS=false
RUN_SEEDS=false

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
GRPC_PORT=50051

# ── AWS S3 / MinIO ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_SESSION_TOKEN=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=ai-service-documents
# Internal endpoint used by backend services to talk to MinIO
AWS_S3_ENDPOINT_URL=http://minio:9000
# Public URL returned to clients (e.g. browser-accessible MinIO)
AWS_S3_PUBLIC_URL=http://localhost:9000

# ── LLM ──────────────────────────────────────────────────────
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
LLM_EMBEDDING_MODEL=gemini-embedding-001
LLM_EMBEDDING_DIMENSION=768
LLM_API_KEY=
LLM_HOST=http://localhost:11434
LLM_USE_VERTEX_AI=false
LLM_VERTEX_PROJECT=
LLM_VERTEX_LOCATION=us-central1

# ── OCR ──────────────────────────────────────────────────────
OCR_PROVIDER=ppstructure
OCR_LANG=vi
OCR_USE_GPU=true

# ── Auth / JWT ───────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept

# ── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=Dherta AI Service
FRONTEND_URL=http://localhost:3000

# ── Kafka consumer ───────────────────────────────────────────
KAFKA_CONSUMER_GROUP_ID=dherta-ai-service
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest

# ── Misc ─────────────────────────────────────────────────────
QUESTION_GROUPING_THRESHOLD=0.8
